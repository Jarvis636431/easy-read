{
  "name": "easy-read",
  "displayName": "Easy read",
  "version": "0.0.1",
  "description": "A basic Plasmo extension.",
  "author": "Jarvis",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "prettier": "3.2.4",
    "typescript": "5.3.3"
  },
  "manifest": {
    "permissions": [
      "activeTab",
      "declarativeNetRequest",
      "storage"
    ],
    "host_permissions": [
      "http://*/*",
      "https://*/*"
    ],
    "declarative_net_request": {
      "rule_resources": [
        {
          "id": "easy_read_ads",
          "enabled": true,
          "path": "~rules/ads.json"
        }
      ]
    }
  }
}
